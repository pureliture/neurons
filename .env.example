# Copy to .env and replace placeholder values before running llm-brain-core.
# Do not commit .env or files under ./secrets.

COMPOSE_PROFILES=llm-brain-core

LLM_BRAIN_COUCHDB_PORT=15984
LLM_BRAIN_COUCHDB_DB=transcript_source
LLM_BRAIN_COUCHDB_USER=neurons
LLM_BRAIN_COUCHDB_PASSWORD=replace-with-local-couchdb-password
LLM_BRAIN_COUCHDB_SECRET=replace-with-local-couchdb-cookie-secret

LLM_BRAIN_LEDGER_POSTGRES_PORT=15432
LLM_BRAIN_LEDGER_POSTGRES_DB=neurons_ledger
LLM_BRAIN_LEDGER_POSTGRES_USER=neurons
LLM_BRAIN_LEDGER_POSTGRES_PASSWORD=replace-with-local-postgres-password

LLM_BRAIN_NEO4J_HTTP_PORT=17474
LLM_BRAIN_NEO4J_BOLT_PORT=17687
LLM_BRAIN_NEO4J_USER=neo4j
LLM_BRAIN_NEO4J_PASSWORD=replace-with-local-neo4j-password

LLM_BRAIN_VERTEX_WRAPPER_IMAGE=vertex-wrapper:local
LLM_BRAIN_VERTEX_WRAPPER_PORT=18930
LLM_BRAIN_VERTEX_WRAPPER_CONTAINER_PORT=8080
LLM_BRAIN_VERTEX_ADC_PATH=./secrets/vertex-adc.json
GOOGLE_APPLICATION_CREDENTIALS=/var/run/llm-brain/adc/application_default_credentials.json

LLM_BRAIN_LLM_MODEL=gemma-4-26b-a4b-it-maas
LLM_BRAIN_SMALL_LLM_MODEL=gemma-4-26b-a4b-it-maas
LLM_BRAIN_LLM_REASONING_EFFORT=none
LLM_BRAIN_EMBEDDING_MODEL=gemini-embedding-2
LLM_BRAIN_EMBEDDING_DIM=3072
# Hot path is episode-only by default: no per-session Graphiti entity extraction.
# Per-session semantic extraction is debug/manual opt-in only (graph-trigger
# --extract-entities / --reextract-entities). Operational semantic enrichment runs
# through the bulk semantic lane below, never inline on the hot path.
LLM_BRAIN_GRAPH_EXTRACT_ENTITIES=false
LLM_BRAIN_GRAPH_WRITE_TIMEOUT_SECONDS=1200

LLM_BRAIN_GRAPH_TRIGGER_INTERVAL_SECONDS=300
LLM_BRAIN_GRAPH_TRIGGER_LIMIT=25
LLM_BRAIN_GRAPH_TRIGGER_PROJECT=
LLM_BRAIN_GRAPH_TRIGGER_PROVIDER=
LLM_BRAIN_GRAPH_TRIGGER_REPORT_EVERY=25

# Bulk semantic lane (off by default). The lane only runs when its dedicated
# compose profile is selected:
#   docker compose --profile llm-brain-bulk-semantic up llm-brain-bulk-semantic-trigger
# Allowed models: Cloud Vertex AI Model Garden MaaS Gemma-4 (chat/extraction) and the
# embedding model above only. Gemini / Gemini Flash chat/extraction is forbidden.
# Per-call extractor knobs (read by couchdb-graph-bulk-semantic):
LLM_BRAIN_BULK_SEMANTIC_MAX_SESSIONS_PER_CALL=5
LLM_BRAIN_BULK_SEMANTIC_MAX_SESSION_CHARS=1600
LLM_BRAIN_BULK_SEMANTIC_MAX_TOKENS=4096
LLM_BRAIN_BULK_SEMANTIC_TIMEOUT_SECONDS=600
LLM_BRAIN_BULK_SEMANTIC_EMBEDDINGS=true
LLM_BRAIN_BULK_SEMANTIC_ALLOW_EMPTY_SESSIONS=false
# Bulk trigger scheduler knobs. Real off-switch is the compose profile above;
# this advisory flag documents intent and is not the gate.
LLM_BRAIN_BULK_SEMANTIC_TRIGGER_ENABLE=false
LLM_BRAIN_BULK_SEMANTIC_TRIGGER_INTERVAL_SECONDS=900
LLM_BRAIN_BULK_SEMANTIC_TRIGGER_LIMIT=100
LLM_BRAIN_BULK_SEMANTIC_TRIGGER_MAX_PROJECTS=5
LLM_BRAIN_BULK_SEMANTIC_TRIGGER_PROJECT=
LLM_BRAIN_BULK_SEMANTIC_TRIGGER_PROVIDER=
LLM_BRAIN_BULK_SEMANTIC_TRIGGER_REPORT_EVERY=25

# RetiredIndexBridge recall projection target. Single credential rule: only RETIRED_INDEX_BRIDGE_API_KEY.
# Do not introduce RETIRED_INDEX_BRIDGE_WRITE_TOKEN / RETIRED_INDEX_BRIDGE_READ_TOKEN.
RETIRED_INDEX_BRIDGE_API_KEY=replace-with-index-api-key
RETIRED_INDEX_BRIDGE_BASE_URL=http://127.0.0.1:9380
# Dataset ids resolve per logical targetProfile; supply your own RetiredIndexBridge dataset ids.
RETIRED_INDEX_BRIDGE_TRANSCRIPT_MEMORY_DATASET_ID=
RETIRED_INDEX_BRIDGE_SESSION_MEMORY_DATASET_ID=
RETIRED_INDEX_BRIDGE_SESSION_SUMMARY_DATASET_ID=
RETIRED_INDEX_BRIDGE_PROJECT_MEMORY_DATASET_ID=
RETIRED_INDEX_BRIDGE_PROCEDURAL_MEMORY_DATASET_ID=
RETIRED_INDEX_BRIDGE_APPROVED_MEMORY_CARD_DATASET_ID=
RETIRED_INDEX_BRIDGE_TASK_SUMMARY_DATASET_ID=

# Ledger state authority (PostgreSQL DSN). Empty -> SQLite seam per ADR-0003 for the
# default ledger, but REQUIRED (non-empty) for the llm-brain-mcp profile (${NEURON_LEDGER_PG_DSN:?}).
NEURON_LEDGER_PG_DSN=

# Embedding endpoint key (only if your embedding provider needs a separate key).
LLM_BRAIN_EMBEDDING_API_KEY=

# ── profile: llm-brain-mcp (neuron-knowledge-mcp) ──
# Required. MCP HTTP binds the Tailscale tailnet interface ONLY — never 0.0.0.0.
MCP_HTTP_HOST=replace-with-tailnet-ip
MCP_HTTP_PORT=8765
# Required. Server-side brain env file path supplied at DEPLOY time. This is NOT this
# repo's .env — it is a path on the deploy host, e.g. /home/ops/Projects/neurons/.env
LLM_BRAIN_ENV_FILE=replace-with-server-brain-env-path

# ── profile: searchable-mirror (optional, off by default) ──
# MIRROR_DUAL_WRITE=0
# QDRANT_URL=
# QDRANT_COLLECTION=
# QDRANT_IMAGE=qdrant/qdrant:latest

# ── live ingress lane switches (optional; default = SAFE shadow/off) ──
# RAG_INGRESS_ALLOW_LIVE_QUEUE=0
# RAG_INGRESS_DELIVER=0
