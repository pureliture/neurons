# session-memory / ledger worker 컨테이너 (Modular Monolith 단일 컨테이너).
# 호스트 cron + bare python3 배포를 대체. ledger(builder)·3 GC·backfill을 스케줄로
# 실행. session-memory projection은 CouchDB source에서 Qdrant searchable mirror로 보낸다.
FROM python:3.13-slim

ARG NEURONS_SOURCE_COMMIT
RUN printf '%s' "${NEURONS_SOURCE_COMMIT}" | grep -Eq '^[0-9a-f]{40}$'
LABEL org.opencontainers.image.revision=${NEURONS_SOURCE_COMMIT}
LABEL org.opencontainers.image.source="https://github.com/pureliture/neurons"

ENV PYTHONDONTWRITEBYTECODE=1
ENV PYTHONUNBUFFERED=1

WORKDIR /app

# 스케줄링은 entrypoint의 경량 bash 루프(외부 cron 바이너리 의존 없음).
# agent_knowledge 패키지 + runtime 의존성 설치(pip install . → PYTHONPATH 불필요).
COPY pyproject.toml ./
COPY lib ./lib
RUN pip install --no-cache-dir . \
    && pip install --no-cache-dir "psycopg[binary]" "qdrant-client>=1.10" "openai>=1.0"

COPY deploy/session-memory/ ./deploy/
RUN chmod +x deploy/entrypoint.sh deploy/build-once.sh

RUN mkdir -p /app/state /shadow

ENTRYPOINT ["/app/deploy/entrypoint.sh"]
